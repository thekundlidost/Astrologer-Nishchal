# ─── Public site config (safe to expose; baked into the client bundle) ───
NEXT_PUBLIC_SITE_URL=https://www.thekundlidost.com
NEXT_PUBLIC_WHATSAPP_NUMBER=917016501873
NEXT_PUBLIC_PHONE_NUMBER=+91 70165 01873
NEXT_PUBLIC_CONTACT_EMAIL=thekundlidost@gmail.com

# ─── Cloudflare Turnstile (spam protection) ───
# Get keys at https://dash.cloudflare.com → Turnstile.
# The SITE key is public (client). Leave blank to disable the widget in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# The SECRET key must ONLY be used server-side (e.g. a serverless verify
# function). NEVER prefix it with NEXT_PUBLIC_ or it will leak to the browser.
TURNSTILE_SECRET_KEY=

# ─── Analytics (Phase 1/2) — leave blank to keep disabled ───
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID — leave blank until you have one
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Growth features ───
# Google Business Profile URL (activates the card in "Find Us Online")
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
# Set to "true" to reveal the language switcher once Hindi translations are added
NEXT_PUBLIC_I18N_ENABLED=
